rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Prevent users from escalating their own plan, limits, or usage stats client-side.
      // These fields are only ever written by the server-side Admin SDK (API routes).
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['plan', 'interviewsLimit', 'resumesLimit',
                                 'interviewsUsed', 'resumesUsed', 'resumeDownloadsLeft',
                                 'planExpiresAt']);
    }
    match /interviews/{interviewId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Require a valid timestamp on create to prevent arbitrary document injection.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.startedAt is timestamp;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /resumes/{resumeId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Require a valid timestamp on create to prevent arbitrary document injection.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.updatedAt is timestamp;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid
                    // Prevent client from self-granting paid download access.
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['isPaidDownload']);
    }
    match /payments/{paymentId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Payments are only ever written by the Admin SDK in /api/payments/verify.
      allow create, update: if false;
    }
  }
}
